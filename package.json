{
  "name": "file-manager-app",
  "version": "1.0.0",
  "description": "File Manager with React UI and API Routes",
  "main": "server.js",
  "homepage": "https://bxbzzbbbm-cmyk.github.io/refactored-engine",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
